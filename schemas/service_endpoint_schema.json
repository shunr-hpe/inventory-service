{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://inventory-service.openchami.org/schemas/service_endpoint_schema.json",
  "title": "ServiceEndpointSpec",
  "type": "object",
  "required": ["RedfishEndpointID", "RedfishType"],
  "properties": {
    "description": {
      "type": "string"
    },
    "RedfishEndpointID": {
      "type": "string",
      "minLength": 1
    },
    "RedfishType": {
      "type": "string",
      "minLength": 1
    },
    "RedfishSubtype": {
      "type": "string"
    },
    "UUID": {
      "type": "string"
    },
    "OdataID": {
      "type": "string"
    },
    "RedfishEndpointFQDN": {
      "type": "string"
    },
    "RedfishURL": {
      "type": "string"
    },
    "ServiceInfo": {
      "type": "object"
    }
  }
}
