{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://inventory-service.openchami.org/schemas/redfish_endpoint_schema.json",
  "title": "RedfishEndpointSpec",
  "type": "object",
  "required": ["ID"],
  "properties": {
    "description": {
      "type": "string"
    },
    "ID": {
      "type": "string",
      "minLength": 1
    },
    "Type": {
      "type": "string"
    },
    "Name": {
      "type": "string"
    },
    "Hostname": {
      "type": "string"
    },
    "Domain": {
      "type": "string"
    },
    "FQDN": {
      "type": "string"
    },
    "Enabled": {
      "type": "boolean"
    },
    "UUID": {
      "type": "string"
    },
    "User": {
      "type": "string"
    },
    "Password": {
      "type": "string"
    },
    "UseSSDP": {
      "type": "boolean"
    },
    "MACRequired": {
      "type": "boolean"
    },
    "MACAddr": {
      "type": "string"
    },
    "IPAddress": {
      "type": "string"
    },
    "RediscoverOnUpdate": {
      "type": "boolean"
    },
    "TemplateID": {
      "type": "string"
    },
    "DiscoveryInfo": {
      "type": "object",
      "properties": {
        "LastDiscoveryAttempt": {
          "type": "string"
        },
        "LastDiscoveryStatus": {
          "type": "string"
        },
        "RedfishVersion": {
          "type": "string"
        }
      }
    }
  }
}
