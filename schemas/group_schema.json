{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://inventory-service.openchami.org/schemas/group_schema.json",
  "title": "Group",
  "type": "object",
  "required": ["spec"],
  "properties": {
    "apiVersion": {
      "type": "string"
    },
    "kind": {
      "type": "string"
    },
    "metadata": {
      "type": "object"
    },
    "id": {
      "type": "string"
    },
    "spec": {
      "type": "object",
      "required": ["label"],
      "properties": {
        "description": {
          "type": "string"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "exclusiveGroup": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "members": {
          "type": "object",
          "properties": {
            "ids": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "status": {
      "type": "object"
    }
  }
}
