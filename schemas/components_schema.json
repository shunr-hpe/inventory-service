{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://inventory-service.openchami.org/schemas/components_schema.json",
  "title": "ComponentSpec",
  "type": "object",
  "required": ["ID"],
  "properties": {
    "description": {
      "type": "string"
    },
    "ID": {
      "type": "string",
      "minLength": 1
    },
    "Type": {
      "type": "string"
    },
    "State": {
      "type": "string"
    },
    "Flag": {
      "type": "string"
    },
    "Enabled": {
      "type": "boolean"
    },
    "SoftwareStatus": {
      "type": "string"
    },
    "Role": {
      "type": "string"
    },
    "SubRole": {
      "type": "string"
    },
    "NID": {
      "type": "number"
    },
    "Subtype": {
      "type": "string"
    },
    "NetType": {
      "type": "string"
    },
    "Arch": {
      "type": "string"
    },
    "Class": {
      "type": "string"
    },
    "ReservationDisabled": {
      "type": "boolean"
    },
    "Locked": {
      "type": "boolean"
    }
  }
}
